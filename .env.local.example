# ─── NETRA (NCR Events, Transit, Rain & Air) — API keys ─────────────────────
# Copy this file to ".env.local" and fill in the values you have.
# The air-quality, weather and events panels work with NO keys at all
# (events now come from a curated recurring-events baseline, not an API).

# 1) Delhi Open Transit Data (live bus GPS, GTFS-Realtime)
#    Register free at: https://otd.delhi.gov.in  -> "Register" -> get an API key.
OTD_API_KEY=

# 2) RapidAPI key — powers IGI flights (AeroDataBox) and New Delhi train
#    departures (IRCTC). One key, but Subscribe to each of those APIs on
#    rapidapi.com (free plans). No longer used for events.
RAPIDAPI_KEY=

# 3) Public base URL of the deployment (used for sitemap, robots and OG tags).
#    Leave unset for local dev; set to e.g. https://netra.vercel.app in production.
NEXT_PUBLIC_SITE_URL=

# 4) GNews (optional) — live Delhi headlines on the City Pulse strip.
#    Free key (100 req/day) at https://gnews.io. Without it, sample headlines show.
GNEWS_KEY=

# Flights (IGI) and New Delhi train departures reuse RAPIDAPI_KEY above, but that
# key must ALSO be subscribed to AeroDataBox (flights) and an IRCTC API (trains)
# on RapidAPI. Until then those panels show clearly-labelled sample boards.
